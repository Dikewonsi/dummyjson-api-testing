        {
          "name": "Edge cases",
          "item": [
            {
              "name": "Limit products with zero",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/products?limit=0",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "products"
                  ],
                  "query": [
                    {
                      "key": "limit",
                      "value": "0"
                    }
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"limit=0 returns all products\", function () {",
                      "    const jsonData = pm.response.json();",
                      "    pm.expect(jsonData.products.length).to.eql(194);",
                      "    pm.expect(jsonData.limit).to.eql(194);",
                      "    pm.expect(jsonData.total).to.eql(194);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Limit products with very large value",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/products?limit=1000",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "products"
                  ],
                  "query": [
                    {
                      "key": "limit",
                      "value": "1000"
                    }
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"limit=1000 returns available total products only\", function () {",
                      "    const jsonData = pm.response.json();",
                      "    pm.expect(jsonData.products.length).to.eql(194);",
                      "    pm.expect(jsonData.limit).to.eql(194);",
                      "    pm.expect(jsonData.total).to.eql(194);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Skip products with negative value",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/products?skip=-1",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "products"
                  ],
                  "query": [
                    {
                      "key": "skip",
                      "value": "-1"
                    }
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"skip=-1 is accepted and echoed in response\", function () {",
                      "    const jsonData = pm.response.json();",
                      "    pm.expect(jsonData.products.length).to.eql(30);",
                      "    pm.expect(jsonData.skip).to.eql(-1);",
                      "    pm.expect(jsonData.limit).to.eql(30);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
