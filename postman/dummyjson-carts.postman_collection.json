            {
              "name": "Get all carts",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/carts",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "carts"
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"Carts list is returned\", function () {",
                      "    const jsonData = pm.response.json();",
                      "    pm.expect(jsonData.carts).to.be.an(\"array\");",
                      "    pm.expect(jsonData.carts.length).to.eql(30);",
                      "    pm.expect(jsonData.total).to.eql(208);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
